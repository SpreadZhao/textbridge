#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: textbridge-adb-connect [--port PORT] [--serial DEVICE] [--remove] [--list]

Create an adb reverse tunnel for TextBridge USB/ADB mode.

Options:
  --port PORT       Desktop TextBridge server TCP port. Defaults to 17321.
  --serial DEVICE   adb device serial to use when multiple devices are connected.
  --remove          Remove the reverse tunnel for the selected port.
  --list            List reverse tunnels for the selected device.
  -h, --help        Show this help.
EOF
}

fail() {
  echo "textbridge-adb-connect: $*" >&2
  exit 1
}

port=17321
serial=""
action="connect"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --port)
      [ "$#" -ge 2 ] || fail "--port requires a value"
      port="$2"
      shift 2
      ;;
    --serial)
      [ "$#" -ge 2 ] || fail "--serial requires a value"
      serial="$2"
      shift 2
      ;;
    --remove)
      action="remove"
      shift
      ;;
    --list)
      action="list"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      fail "unknown argument: $1"
      ;;
  esac
done

[[ "$port" =~ ^[0-9]+$ ]] || fail "port must be an integer"
if [ "$port" -lt 1 ] || [ "$port" -gt 65535 ]; then
  fail "port must be between 1 and 65535"
fi

select_device() {
  if [ -n "$serial" ]; then
    return
  fi

  local devices=()
  while IFS= read -r device; do
    [ -n "$device" ] && devices+=("$device")
  done < <(adb devices | awk 'NR > 1 && $2 == "device" { print $1 }')

  case "${#devices[@]}" in
    0)
      fail "no authorized adb device found"
      ;;
    1)
      serial="${devices[0]}"
      ;;
    *)
      echo "Multiple adb devices are connected:" >&2
      printf '  %s\n' "${devices[@]}" >&2
      fail "pass --serial DEVICE"
      ;;
  esac
}

select_device

adb_args=(-s "$serial")
case "$action" in
  connect)
    adb "${adb_args[@]}" reverse "tcp:$port" "tcp:$port"
    echo "ADB reverse ready for $serial"
    echo "Android address: 127.0.0.1:$port"
    ;;
  remove)
    adb "${adb_args[@]}" reverse --remove "tcp:$port"
    echo "ADB reverse removed for $serial tcp:$port"
    ;;
  list)
    adb "${adb_args[@]}" reverse --list
    ;;
esac
